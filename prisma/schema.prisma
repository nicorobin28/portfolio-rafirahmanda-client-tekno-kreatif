// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  password     String
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relasi
  profile      Profile?
  portfolios   Portfolio[]
  areaOfFocus  AreaOfFocus[]
  experiences  Experience[]

  @@map("users")
}

// ─────────────────────────────────────────────
// PROFILE — informasi publik yang bisa diedit
// ─────────────────────────────────────────────

model Profile {
  id                 String   @id @default(cuid())
  userId             String   @unique  // one-to-one dengan User
  email              String?
  linkedin           String?
  portfolioFileUrl   String?  // URL file PDF portfolio
  portfolioFileName  String?  // nama file asli untuk ditampilkan
  resumeFileUrl      String?  // URL file PDF resume
  resumeFileName     String?  // nama file asli untuk ditampilkan
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ─────────────────────────────────────────────
// PORTFOLIO
// ─────────────────────────────────────────────

model Portfolio {
  id        String   @id @default(cuid())
  userId    String
  title     String
  subTitle  String   @default("")
  role      String   // peran saat mengerjakan, contoh: "UI/UX Designer"
  company   String
  year      Int      // contoh: 2024
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  images   PortfolioImage[]
  contents PortfolioContent[]
  tags     PortfolioTag[]

  @@map("portfolios")
}

model PortfolioImage {
  id          String   @id @default(cuid())
  portfolioId String
  url         String   // URL gambar di storage (R2/S3)
  altText     String?  // alt text untuk aksesibilitas
  order       Int      @default(0)  // urutan tampil gambar
  anchorContentId String?
  anchorPosition  ImageAnchorPosition?
  createdAt   DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  anchorContent PortfolioContent? @relation("ImageAnchor", fields: [anchorContentId], references: [id], onDelete: SetNull)


  @@map("portfolio_images")
}

enum ImageAnchorPosition {
  BEFORE
  AFTER
}

model PortfolioContent {
  id          String   @id @default(cuid())
  portfolioId String
  title       String   // judul section konten
  body        String   @db.Text  // output HTML dari rich text editor (Tiptap)
  order       Int      @default(0)  // urutan section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  anchoredImages PortfolioImage[] @relation("ImageAnchor")

  @@map("portfolio_contents")
}

// ─────────────────────────────────────────────
// AREA OF FOCUS — dinamis, bisa ditambah/dihapus
// ─────────────────────────────────────────────

model AreaOfFocus {
  id        String   @id @default(cuid())
  userId    String
  label     String   // contoh: "UI/UX Design", "Product Design"
  order     Int      @default(0)  // urutan tampil
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("area_of_focus")
}

model Tag {
  id        String   @id @default(cuid())
  label     String   @unique  // unik secara global, contoh: "Mobile App", "Branding"
  color     String?           // opsional: hex color untuk badge, misal "#FF5733"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  portfolios PortfolioTag[]   // join table

  @@map("tags")
}

// Join table — Portfolio ↔ Tag (many-to-many)
model PortfolioTag {
  portfolioId String
  tagId       String

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([portfolioId, tagId])
  @@map("portfolio_tags")
}

// ─────────────────────────────────────────────
// EXPERIENCE — timeline pekerjaan
// ─────────────────────────────────────────────

model Experience {
  id        String   @id @default(cuid())
  userId    String
  company   String   // nama perusahaan
  position  String   // posisi / jabatan
  startDate String   // format: "2022-01" → ditampilkan sebagai "Jan 2022"
  endDate   String?  // null jika isCurrent = true
  isCurrent Boolean  @default(false)  // masih bekerja di sini
  order     Int      @default(0)  // urutan di timeline (terbaru = 0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("experiences")
}
